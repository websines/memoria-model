# Copy to .env and fill in your tokens

# HuggingFace — for pushing model checkpoints
# Get yours at: https://huggingface.co/settings/tokens (write access)
HF_TOKEN=xxx
HF_REPO=Mazino0/memoria-prototype  # your HF model repo

# Weights & Biases — for training observability
# Get yours at: https://wandb.ai/authorize
WANDB_API_KEY=xxx
WANDB_PROJECT=memoria_prototype
